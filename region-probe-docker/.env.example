REGION_PROBE_IMAGE=ghcr.io/wangzhilin777/region-probe-docker:latest
HOST_PORT=8226
LISTEN_HOST=0.0.0.0
LISTEN_PORT=8080
TRACE_HOST=speed.cloudflare.com
TRACE_PATH=/cdn-cgi/trace
TLS_SERVER_NAME=speed.cloudflare.com
CONNECT_TIMEOUT=3.5
READ_TIMEOUT=4.5
MAX_WORKERS=24
MAX_TARGETS=500
REGION_PROBE_TOKEN=changeme

# 不走代理就留空
# 例子:
# PROXY_URL=socks5://192.168.31.10:7891
# PROXY_URL=socks5h://127.0.0.1:7891
# PROXY_URL=http://127.0.0.1:7890
PROXY_URL=

# true 时让 socks5h / 代理侧解析域名，默认 false
PROXY_REMOTE_DNS=false
